{
  "manifest_version": 3,
  "name": "Patpat Ajan",
  "version": "0.2.0",
  "description": "Dosya tabanlı tarama, senkron ve yan panel yönetimi.",
  "action": {
    "default_title": "Patpat Agent"
  },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "host_permissions": [
    "https://hesap.com.tr/*",
    "https://anabayiniz.com/*",
    "https://script.google.com/*"
  ],
  "permissions": [
    "storage",
    "unlimitedStorage",
    "sidePanel",
    "tabs",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://hesap.com.tr/p/sattigim-ilanlar*",
        "https://hesap.com.tr/ilanlar/*"
      ],
      "js": [
        "content.js",
        "content-crawler.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://anabayiniz.com/orders*"
      ],
      "js": [
        "content.js",
        "content-crawler.js"
      ],
      "run_at": "document_idle"
    }
  ]
}